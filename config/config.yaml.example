# Money Flow Momentum - Bybit V5 Trading Bot Config
# Copy to config.yaml and customize
#
# Top-level operating mode (recommended):
#   demo_research  - Autonomous Demo: trade, evaluate, optimize, shadow on Demo; no manual approval during research.
#   live_guarded   - Guarded Live: stricter limits; config and Demo->Live promotion require manual approval.
# Omit to derive from env/automation/burn_in (Demo+automation+demo phase -> demo_research; else live_guarded).
operating_mode: demo_research

mode: paper  # dry_run | paper | live
dry_run: false  # true = simulated entries only (no orders); false = place real orders on selected env (Demo/Live)

exchange:
  testnet: true
  one_way_mode: true
  default_leverage: 5
  request_timeout: 10.0
  ws_ping_interval: 20.0
  ws_reconnect_delay: 5.0
  max_reconnect_attempts: 10
  rate_limit_requests_per_second: 5.0

universe:
  min_24h_turnover_usdt: 1000000
  max_spread_bps: 50
  min_notional_usdt: 100
  allowlist: []   # e.g. ["BTCUSDT", "ETHUSDT"]
  blocklist: []   # e.g. ["LUNAUSDT"]
  status_filter: Trading
  quote_coin: USDT

features:
  window_30s: 30
  window_1m: 60
  window_3m: 180
  window_5m: 300
  atr_period: 14
  volatility_window: 60

score_weights:
  w1_delta_1m: 0.25
  w2_cvd_slope_3m: 0.20
  w3_buy_sell_ratio_1m: 0.20
  w4_price_return_1m: 0.15
  w5_oi_change: 0.10
  w6_spread_penalty: 0.05
  w7_funding_penalty: 0.05

entry:
  long_threshold: 1.5
  short_threshold: -1.5
  min_delta_1m: 0.0
  min_buy_sell_ratio_long: 1.05
  max_buy_sell_ratio_short: 0.95
  max_spread_bps: 30
  max_atr_extension: 2.0
  divergence_bonus: 0.3
  max_correlation_positions: 5

stop_tp:
  atr_multiplier_sl: 1.5
  tp1_r_multiple: 1.0
  tp2_r_multiple: 2.0
  tp1_pct: 0.33
  tp2_pct: 0.33
  breakeven_after_tp1: true
  max_hold_seconds: 3600
  flow_reversal_exit: true
  flow_reversal_delta_threshold: -0.5
  trailing_stop_atr_multiple: 1.0
  time_stop_bars: 60

risk:
  risk_per_trade_pct: 0.5
  max_concurrent_positions: 5
  max_positions_per_side: 3
  max_total_risk_pct: 2.0
  max_daily_drawdown_pct: 5.0
  max_daily_realized_loss_usdt: 500
  max_notional_per_symbol_usdt: 10000
  max_portfolio_notional_usdt: 50000
  min_notional_per_trade_usdt: 10
  cooldown_after_loss_seconds: 300
  reentry_cooldown_seconds: 60
  kill_switch_enabled: true
  stale_data_seconds: 60.0
  max_trades_per_hour: 30
  api_error_threshold: 10
  symbol_cooldown_after_stop_seconds: 600

execution:
  use_market_orders: true
  slippage_bps: 20
  post_only_limit: false
  reduce_only_exits: true
  idempotent_order_link: true

logging:
  level: INFO
  structured: true
  log_file: null
  rotation: "10 MB"
  retention: "7 days"

database_path: data/bot.db
scan_interval_seconds: 5.0
score_interval_seconds: 5.0
health_check_interval_seconds: 30.0

# Context refresh (seconds)
kline_refresh_seconds: 60
oi_refresh_seconds: 60
funding_refresh_seconds: 300
long_short_ratio_refresh_seconds: 300
instrument_refresh_seconds: 600
context_staleness_seconds: 120

# WebSocket
public_ws_max_symbols_per_connection: 50
public_ws_stale_timeout_seconds: 90
private_ws_stale_timeout_seconds: 120

# Reconciliation and recovery
rest_reconciliation_interval_seconds: 60
recover_orphan_positions: true
emergency_flatten_on_startup: false

# Protection / trailing / shards
trailing_stop_update_seconds: 15
shard_reconnect_backoff_seconds: 30
repair_missing_protection_on_startup: true
startup_protection_required: false
runner_trailing_enabled: true

# Burn-in and live validation (see docs/BURN_IN_OPERATOR_RUNBOOK.md)
# With operating_mode: demo_research these are set automatically (permissive for research).
# With operating_mode: live_guarded use stricter limits.
# burn_in:
#   burn_in_enabled: true
#   burn_in_phase: demo   # demo | testnet | live_small | live_guarded
#   burn_in_max_trades_per_day: 200
#   burn_in_max_notional_usdt: 500000
#   burn_in_required_report_window_hours: 24.0
#   burn_in_min_expected_heartbeat_coverage: 0.8
#   burn_in_fail_on_protection_mismatch: true
#   burn_in_fail_on_execution_drift: true
#   burn_in_max_slippage_bps: 50.0
#   burn_in_max_reconnect_per_hour: 5

# Demo orchestration (with operating_mode: demo_research these are enabled automatically)
# automation:
#   enabled: true
#   demo_orchestration_enabled: true
#   readiness_check_interval_seconds: 900.0
#   min_trades_for_auto_evaluation: 50
#   min_hours_between_evaluations: 6.0
#   min_hours_between_optimizer_runs: 24.0
#   auto_start_shadow_for_best_candidate: true
#   require_readiness_for_optimizer: true
#   pause_on_kill_switch: true
#   pause_on_burnin_gate_breach: true
#   # Demo-only auto-adopt: automatically activate a better candidate as Demo active config (never touches Live)
#   auto_adopt_demo_candidates: false
#   min_trades_for_demo_adoption: 50
#   min_hours_between_demo_adoptions: 24.0
#   require_shadow_before_demo_adoption: false
#
# Demo-only research mode (operating_mode: demo_research). Ignored in live_guarded.
# demo_research:
#   fixed_equity_enabled: true
#   fixed_equity_usdt: 1000.0
#   relaxed_kill_switch_enabled: true
#   demo_max_daily_drawdown_pct: 15.0
#   demo_max_daily_realized_loss_usdt: 150.0
#   demo_research_burnin_permissive: true
