# Bybit API credentials - NEVER commit real keys
# Environment: demo (recommended burn-in) | live | testnet (legacy)
BYBIT_ENV=demo

# Dual-key (recommended): demo = Bybit Demo Trading keys from mainnet account Demo mode
BYBIT_DEMO_API_KEY=
BYBIT_DEMO_API_SECRET=
# Live/mainnet
BYBIT_LIVE_API_KEY=
BYBIT_LIVE_API_SECRET=

# Legacy: optional single-key fallback (used when dual-key for selected env not set)
# BYBIT_API_KEY=
# BYBIT_API_SECRET=

# Legacy testnet keys (only when BYBIT_ENV=testnet; prefer demo for burn-in)
# BYBIT_TESTNET_API_KEY=
# BYBIT_TESTNET_API_SECRET=
# Deprecated: use BYBIT_ENV instead. true=testnet, false=live
# BYBIT_TESTNET=true
